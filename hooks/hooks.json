{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; node \"$_R/scripts/dist/service.cjs\" hook session-start",
						"timeout": 30
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; node \"$_R/scripts/dist/service.cjs\" hook session-stop",
						"timeout": 15
					}
				]
			}
		]
	}
}
